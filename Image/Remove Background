#!/usr/bin/env python3
import site
import os
import sys
from pathlib import Path

script_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, script_dir)
from package_installer import install_deps_to_default_venv

deps_dir = install_deps_to_default_venv(deps=["torch", "torchvision"], params=["--index-url", "https://download.pytorch.org/whl/cu121"])
deps_dir = install_deps_to_default_venv(deps=[('pillow', 'PIL'), 'transformers', 'kornia', 'timm'])

sys.path.insert(0, deps_dir)
site.addsitedir(deps_dir)

import torch
from PIL import Image
from torchvision import transforms
from transformers import AutoModelForImageSegmentation

def run(file_arg: str) -> str:
    # Paths
    input_path = Path(file_arg)
    output_path = str(input_path.with_name(f"{input_path.stem}_converted.png"))

    # Device
    device = "cuda" if torch.cuda.is_available() else "cpu"
    torch.set_float32_matmul_precision("high")

    # Model
    model = AutoModelForImageSegmentation.from_pretrained(
        "ZhengPeng7/BiRefNet",
        trust_remote_code=True
    ).to(device)
    model.eval()

    # Data settings
    image_size = (1024, 1024)
    transform_image = transforms.Compose([
        transforms.Resize(image_size),
        transforms.ToTensor(),  # -> [C,H,W] in [0,1], C=3 after .convert('RGB')
        transforms.Normalize([0.485, 0.456, 0.406],
                             [0.229, 0.224, 0.225]),
    ])

    # Load image as RGB (avoid 4-channel RGBA causing normalize crash)
    orig = Image.open(file_arg).convert("RGB")
    inp = transform_image(orig).unsqueeze(0).to(device)  # [1,3,H,W]

    # Predict
    with torch.no_grad():
        if device == "cuda":
            # Autocast speeds up & saves memory without manual .half()
            with torch.autocast(device_type="cuda", dtype=torch.float16):
                out = model(inp)
        else:
            out = model(inp)

    # Handle different return structures
    if isinstance(out, (list, tuple)):
        seg = out[-1]
    elif hasattr(out, "logits"):
        seg = out.logits
    else:
        seg = out

    # Convert to sigmoid mask on CPU
    preds = torch.sigmoid(seg).detach().cpu()
    pred = preds[0].squeeze()           # [H,W] or [1,H,W] -> [H,W]
    mask_pil = transforms.ToPILImage()(pred)  # mode 'L' automatically
    mask_pil = mask_pil.resize(orig.size, Image.BILINEAR)

    # Apply alpha and save
    result = orig.convert("RGBA")
    result.putalpha(mask_pil)
    result.save(output_path)

    return output_path

def main():
    if len(sys.argv) < 2:
        print(f"Usage: {sys.argv[0]} <file1> [<file2> ...]")
        sys.exit(1)

    for file in sys.argv[1:]:
        out = run(file)

        # Optional notification
        try:
            from gi.repository import Notify  # type: ignore
            Notify.init("Background Remover")
            notification = Notify.Notification.new(
                "Background removed",
                f"{out}",
                "edit-copy"
            )
            notification.show()
        except Exception:
            pass  # Notifications are best-effort

if __name__ == "__main__":
    main()
